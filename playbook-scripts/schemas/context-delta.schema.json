{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://instar.dev/schemas/context-delta.schema.json",
  "title": "Context Delta",
  "description": "Schema for Playbook context deltas — proposed changes to the manifest, validated by the deterministic delta validator.",
  "type": "object",
  "required": ["delta_id", "timestamp", "source_session", "operation", "reflector_confidence"],
  "properties": {
    "delta_id": {
      "type": "string",
      "pattern": "^delta-[a-f0-9]{12}$",
      "description": "Unique delta identifier (hex-encoded, 12 chars)."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this delta was proposed."
    },
    "source_session": {
      "type": "string",
      "description": "Session ID that proposed this delta. Pattern is governance-configurable via source_session_pattern."
    },
    "operation": {
      "type": "string",
      "enum": ["create", "update_counter", "update_content", "retire", "merge", "promote", "resolve_quarantine"],
      "description": "The type of manifest change being proposed."
    },
    "target_item_id": {
      "type": "string",
      "pattern": "^/context/[a-z]+/[a-z0-9/-]+$",
      "description": "ID of the manifest item being modified (required for all operations except create)."
    },
    "reflector_confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Reflector's confidence in this delta (0.0-1.0). Below governance threshold routes to pending_review."
    },
    "payload": {
      "$ref": "#/$defs/DeltaPayload",
      "description": "The actual change data — varies by operation type."
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/Evidence" },
      "description": "Evidence supporting this delta. Required for create operations."
    },
    "rationale": {
      "type": "string",
      "maxLength": 500,
      "description": "Brief explanation of why this delta is proposed."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "DeltaPayload": {
      "type": "object",
      "properties": {
        "category": {
          "type": "string",
          "enum": ["identity", "safety", "infrastructure", "strategy", "lesson", "domain"],
          "description": "Item category (required for create operations)."
        },
        "memory_type": {
          "type": "string",
          "enum": ["fact", "experiential", "episodic", "procedural", "historical"],
          "description": "Memory type (required for create operations)."
        },
        "content_inline": {
          "type": "string",
          "maxLength": 2000,
          "description": "Inline content (max ~500 tokens)."
        },
        "path": {
          "type": "string",
          "description": "File path relative to repo root."
        },
        "tags": {
          "type": "object",
          "properties": {
            "domains": {
              "type": "array",
              "items": { "type": "string" },
              "maxItems": 2
            },
            "qualifiers": {
              "type": "array",
              "items": { "type": "string" },
              "maxItems": 3
            }
          },
          "additionalProperties": false
        },
        "field": {
          "type": "string",
          "enum": ["helpful", "misleading"],
          "description": "Counter field to update (for update_counter operations)."
        },
        "increment": {
          "type": "number",
          "enum": [1, -1, 0.5, -0.5],
          "description": "Counter increment value (for update_counter operations)."
        },
        "access_scope": {
          "type": "string",
          "enum": ["global", "session", "user"],
          "description": "Multi-tenant visibility scope."
        },
        "inheritance_eligible": {
          "type": "boolean",
          "description": "Whether sub-agents can inherit this item."
        },
        "retirement_policy": {
          "type": "string",
          "enum": ["auto", "manual_only"],
          "description": "Whether this item can be auto-retired."
        }
      },
      "additionalProperties": false
    },
    "Evidence": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["exit_code", "http_status", "test_result", "human_verification"],
          "description": "Type of evidence supporting this delta."
        },
        "value": {
          "description": "The evidence value (type varies by evidence type)."
        }
      },
      "additionalProperties": false
    }
  }
}
