{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://instar.dev/schemas/context-manifest.schema.json",
  "title": "Context Manifest",
  "description": "Schema for the Playbook context manifest — the single source of truth for an agent's accumulated knowledge items.",
  "type": "object",
  "required": ["version", "items"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Manifest format version."
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the manifest schema."
    },
    "last_lifecycle_run": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last lifecycle job run."
    },
    "migration_stage": {
      "type": "integer",
      "minimum": 0,
      "description": "Current migration stage (0=fresh, 1=seeded, 2=lessons migrated, etc.)."
    },
    "hmac_signature": {
      "type": "string",
      "description": "HMAC-SHA256 signature of the canonical JSON for integrity verification."
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/ManifestItem" },
      "description": "All context items (active, retired, or pending_review)."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ManifestItem": {
      "type": "object",
      "required": ["id", "category", "memory_type", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^/context/",
          "description": "Unique hierarchical item ID (e.g., /context/infrastructure/session)."
        },
        "category": {
          "$ref": "#/$defs/Category",
          "description": "Item category determining governance policy."
        },
        "memory_type": {
          "$ref": "#/$defs/MemoryType",
          "description": "Memory type determining decay rate."
        },
        "path": {
          "type": "string",
          "description": "File path relative to repo root. Empty string for inline-only items."
        },
        "content_inline": {
          "type": "string",
          "maxLength": 2000,
          "description": "Inline content (max ~500 tokens). Used for items without file paths."
        },
        "tags": {
          "$ref": "#/$defs/Tags",
          "description": "Domain and qualifier tags for trigger matching and assembly."
        },
        "freshness": {
          "type": "string",
          "description": "ISO 8601 timestamp of last meaningful update."
        },
        "content_hash": {
          "type": "string",
          "pattern": "^(sha256:[a-f0-9]{16})?$",
          "description": "Truncated SHA-256 hash of file content for drift detection."
        },
        "tokens_est": {
          "type": "integer",
          "minimum": 0,
          "description": "Estimated token count (chars / 4 + 1)."
        },
        "usefulness": {
          "$ref": "#/$defs/Usefulness",
          "description": "Outcome-linked usefulness counters."
        },
        "load_triggers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Triggers that cause this item to be loaded during assembly."
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of items that should be co-loaded with this item."
        },
        "provenance": {
          "type": "array",
          "items": { "$ref": "#/$defs/Provenance" },
          "description": "Provenance chain tracking who created/modified this item."
        },
        "retirement_policy": {
          "type": "string",
          "enum": ["auto", "manual_only"],
          "description": "Whether this item can be automatically retired."
        },
        "access_scope": {
          "type": "string",
          "enum": ["global", "session", "user"],
          "description": "Multi-tenant visibility scope. 'global' = all users/agents, 'session' = current session only, 'user' = specific user namespace."
        },
        "inheritance_eligible": {
          "type": "boolean",
          "description": "Whether sub-agents can inherit this item."
        },
        "status": {
          "type": "string",
          "enum": ["active", "retired", "pending_review"],
          "description": "Current item status."
        },
        "retired_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the item was retired (only present for retired items)."
        }
      },
      "additionalProperties": false
    },
    "Category": {
      "type": "string",
      "enum": ["identity", "safety", "infrastructure", "strategy", "lesson", "domain"]
    },
    "MemoryType": {
      "type": "string",
      "enum": ["fact", "experiential", "episodic", "procedural", "historical"]
    },
    "Tags": {
      "type": "object",
      "required": ["domains", "qualifiers"],
      "properties": {
        "domains": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 2,
          "description": "Domain tags (max 2 per governance)."
        },
        "qualifiers": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 3,
          "description": "Qualifier tags (max 3 per governance)."
        }
      },
      "additionalProperties": false
    },
    "Usefulness": {
      "type": "object",
      "required": ["helpful", "misleading"],
      "properties": {
        "helpful": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of times this item contributed to a successful outcome."
        },
        "misleading": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of times this item contributed to a negative outcome."
        }
      },
      "additionalProperties": false
    },
    "Provenance": {
      "type": "object",
      "required": ["source_session", "created_at", "provenance_type"],
      "properties": {
        "source_session": {
          "type": "string",
          "description": "Session ID that created or modified this provenance entry."
        },
        "created_at": {
          "type": "string",
          "description": "Date when this provenance entry was created."
        },
        "provenance_type": {
          "type": "string",
          "enum": ["human-verified", "system-computed", "llm-evaluated", "imported"],
          "description": "How this provenance was established."
        },
        "note": {
          "type": "string",
          "description": "Optional note about this provenance entry."
        }
      },
      "additionalProperties": false
    }
  }
}
